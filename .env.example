# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/u2e_apartments?schema=public"

# Paystack (card payments)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""

# File storage (verification docs + photos) — provider TBD (UploadThing/S3/Cloudinary)
UPLOADTHING_TOKEN=""

# Transactional email (bank-transfer reference + confirmations) — SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="U2E Apartments <no-reply@example.com>"

# Public site URL (for absolute links / Paystack callbacks)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
