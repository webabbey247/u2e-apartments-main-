  "comments": {
    "overrides": "uploadthing pins effect 3.17.7 while its own @effect/platform (and @prisma/config) resolve 3.20.0 — a 3.20 runtime executing 3.17 Effects logs a version-mismatch warning. Pin one copy; 3.20.0 satisfies @effect/platform's ^3.17.7 and Prisma's exact 3.20.0."
  },
  "overrides": {
    "effect": "3.20.0"
  },
